generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  passwordHash  String
  profileData   String?      // Stored as JSON string (gender, ageGroup, category, fitnessLevel, etc.)
  microcycle    Microcycle?
  dailyLogs     DailyLog[]
  stationPRs    StationPR[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model StationPR {
  id          String   @id @default(cuid())
  userId      String
  station     String   // e.g., "SkiErg", "SledPush", "Run1km"
  timeMs      Int      // Personal record time in milliseconds
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, station])
}

model Microcycle {
  id        String   @id @default(cuid())
  userId    String   @unique
  data      String   // Stored as JSON string (the whole weekly plan)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyLog {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD
  totalTimeMs Int      // total time
  blockLogs   String   // JSON string of block specific logs
  rpe         Int?     // Rating of Perceived Exertion (1-10)
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
