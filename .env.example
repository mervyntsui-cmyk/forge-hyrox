# ============================================================
# FORGE - Environment Variables Template
# Copy this file to .env.local and fill in your own values.
# NEVER commit .env.local to git.
# ============================================================

# ── LLM API (Anthropic-compatible endpoint) ──────────────────
# Option A: Aliyun DashScope (https://dashscope.aliyuncs.com)
# Option B: OpenRouter (https://openrouter.ai)
# Option C: Any Anthropic-compatible provider
ALIYUN_API_KEY=your-api-key-here
LLM_API_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic/v1/messages

# ── NextAuth ──────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Google / Gemini (optional, for alternative AI features) ──
# GEMINI_API_KEY=your-gemini-api-key-here
